# Copy this file to `.env` and fill in your Supabase project values.
# Find these in your Supabase dashboard: Project Settings > API.
# The anon/publishable key is SAFE to expose in the frontend because
# Row-Level Security protects your data. NEVER put the service_role key here.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-publishable-key
